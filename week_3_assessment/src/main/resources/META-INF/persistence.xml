<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="assessment_week3">

        <class>assessment.week3.entity.Order</class>
        <class>assessment.week3.entity.Dish</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver"   value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:mysql://localhost:3306/assessment_week3"/>
            <property name="jakarta.persistence.jdbc.user"     value="mohit"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>

            <property name="hibernate.dialect"      value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql"     value="true"/>
            <property name="hibernate.format_sql"   value="true"/>
        </properties>

    </persistence-unit>
    
    <!-- task5 -->
    <persistence-unit name="assessment_week3_task5">
        <class>assessment.week3.task5.entity.Course</class>
        <class>assessment.week3.task5.entity.Enrollment</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver"   value="com.mysql.cj.jdbc.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:mysql://localhost:3306/assessment_week3"/>
            <property name="jakarta.persistence.jdbc.user"     value="mohit"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="hibernate.dialect"      value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql"     value="true"/>
            <property name="hibernate.format_sql"   value="true"/>
        </properties>
    </persistence-unit>
    
    <!-- task4 -->
    <persistence-unit name="assessment_week3_task4">
    <class>assessment.week3.task4.entity.Member</class>
    <class>assessment.week3.task4.entity.Workout</class>
    <properties>
        <property name="jakarta.persistence.jdbc.driver"   value="com.mysql.cj.jdbc.Driver"/>
        <property name="jakarta.persistence.jdbc.url"      value="jdbc:mysql://localhost:3306/assessment_week3"/>
        <property name="jakarta.persistence.jdbc.user"     value="mohit"/>
        <property name="jakarta.persistence.jdbc.password" value="1234"/>
        <property name="hibernate.dialect"      value="org.hibernate.dialect.MySQLDialect"/>
        <property name="hibernate.hbm2ddl.auto" value="update"/>
        <property name="hibernate.show_sql"     value="true"/>
        <property name="hibernate.format_sql"   value="true"/>
    </properties>
</persistence-unit>

</persistence>